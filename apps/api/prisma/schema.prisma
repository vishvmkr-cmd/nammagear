generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  phone          String?
  passwordHash   String
  name           String
  college        String?
  role           UserRole  @default(USER)
  verifiedAt     DateTime?
  pincode        String
  area           String
  avatarUrl      String?
  rating         Float     @default(0)
  totalSales     Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  listings       Listing[]
  saves          Save[]
  cartItems      CartItem[]
  reports        Report[]  @relation("Reporter")
  orders         Order[]   @relation("Buyer")
  serviceTickets ServiceTicket[]

  @@index([pincode])
  @@index([role])
}

model Category {
  id       String    @id @default(cuid())
  slug     String    @unique
  name     String
  listings Listing[]
}

enum Condition {
  A
  B
  C
}

enum ListingStatus {
  ACTIVE
  SOLD
  REMOVED
}

model Listing {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])
  title       String
  description String
  condition   Condition
  price       Int
  negotiable  Boolean       @default(true)
  pincode     String
  area        String
  ageYears    Float?
  hasBill     Boolean       @default(false)
  status      ListingStatus @default(ACTIVE)
  views       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Detailed specifications (for laptops/electronics)
  processor   String?
  memory      String?
  storage     String?
  display     String?
  graphics    String?
  warrantyType String?
  warrantyFrom String?
  warrantyPeriod String?
  warrantyDetails String?

  images      ListingImage[]
  saves       Save[]
  cartItems   CartItem[]
  reports     Report[]
  orders      Order[]

  @@index([pincode, status])
  @@index([categoryId, status])
  @@index([createdAt])
}

model ListingImage {
  id         String  @id @default(cuid())
  listingId  String
  listing    Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url        String
  order      Int     @default(0)
}

model Save {
  id         String  @id @default(cuid())
  userId     String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId  String
  listing    Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, listingId])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}

model Report {
  id         String  @id @default(cuid())
  reporterId String
  reporter   User    @relation("Reporter", fields: [reporterId], references: [id])
  listingId  String
  listing    Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reason     String
  resolved   Boolean @default(false)
  createdAt  DateTime @default(now())
}

enum OrderStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Order {
  id              String      @id @default(cuid())
  buyerId         String
  buyer           User        @relation("Buyer", fields: [buyerId], references: [id])
  listingId       String
  listing         Listing     @relation(fields: [listingId], references: [id])
  amount          Int
  status          OrderStatus @default(PENDING)
  serviceExpiresAt DateTime
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  serviceTickets  ServiceTicket[]

  @@index([buyerId])
  @@index([listingId])
  @@index([status])
  @@index([serviceExpiresAt])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model ServiceTicket {
  id          String         @id @default(cuid())
  orderId     String
  order       Order          @relation(fields: [orderId], references: [id])
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  subject     String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  resolution  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([orderId])
  @@index([userId])
  @@index([status])
}
