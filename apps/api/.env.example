# Database
DATABASE_URL="postgresql://user:password@localhost:5432/student-gear-shop"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Server (default in code is 4000; must match NEXT_PUBLIC_API_URL on the web app)
PORT=4000
NODE_ENV=development

# CORS — browser origin(s) for the Next app. Comma-separated in production for apex + www.
CORS_ORIGIN="http://localhost:3000"
# Production example:
# CORS_ORIGIN="https://microlynk.shop,https://www.microlynk.shop"

# Cookies — use leading dot so the same cookie works on apex and www
COOKIE_DOMAIN="localhost"
# Production example:
# COOKIE_DOMAIN=".microlynk.shop"

# Migrations: prisma/migrations is the source of truth for production (see `pnpm db:migrate`).
# If your DB was created earlier with `db:push` and already matches the schema, run once from repo root:
# pnpm db:baseline

# --- Google OAuth (optional; omit to disable "Continue with Google") ---
# Public URL of the Next app (no trailing slash). Used to redirect after OAuth.
FRONTEND_ORIGIN="http://localhost:3000"
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client (Web application)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Must match an "Authorized redirect URI" in Google Console exactly.
# Local (Next proxies /api to the API): use the port users open in the browser.
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"
# Production examples:
# FRONTEND_ORIGIN="https://microlynk.shop"
# GOOGLE_REDIRECT_URI="https://microlynk.shop/api/auth/google/callback"
