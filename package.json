{
  "name": "student-gear-shop",
  "private": true,
  "pnpm": {
    "ignoredBuiltDependencies": ["sharp", "unrs-resolver"]
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter student-gear-shop-web dev",
    "dev:api": "pnpm --filter student-gear-shop-api dev",
    "build": "pnpm -r build",
    "start": "pnpm -r start",
    "db:migrate": "pnpm --filter api prisma migrate deploy",
    "db:generate": "pnpm --filter api prisma generate",
    "db:studio": "pnpm --filter api prisma studio"
  },
  "engines": {
    "node": ">=20"
  }
}
