# Copy to deploy/.env and fill in. Used by docker compose for the API service.
JWT_SECRET=change-me-to-a-long-random-string
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Comma-separated browser origins (apex + www)
CORS_ORIGIN=https://microlynk.shop,https://www.microlynk.shop
COOKIE_DOMAIN=.microlynk.shop
